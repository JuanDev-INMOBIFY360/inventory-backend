# 📁 .gitignore

# ============================================
# DEPENDENCIAS
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# COMPILACIÓN
# ============================================
dist/
build/
*.tsbuildinfo

# ============================================
# VARIABLES DE ENTORNO
# ============================================
.env
.env.local
.env.dev
.env.prod
.env.test
.env.*.local

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# BASE DE DATOS
# ============================================
*.sql
*.sqlite
*.db

# ============================================
# EDITORES / IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.iml
.project
.classpath
.settings/

# ============================================
# ARCHIVOS DE SISTEMA
# ============================================
.DS_Store
Thumbs.db
*.tmp
*.temp

# ============================================
# COBERTURA DE CÓDIGO
# ============================================
coverage/
.nyc_output/
*.lcov

# ============================================
# ARCHIVOS DE MIGRACIONES
# ============================================
src/migrations/*.ts
!src/migrations/.gitkeep

# ============================================
# DOCKER
# ============================================
*.pid
docker-compose.override.yml

# ============================================
# OTROS
# ============================================
*.pem
*.key
*.crt
*.cert
sonar-project.properties